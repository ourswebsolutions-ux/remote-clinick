# ===========================================
# CLINIC MANAGEMENT SYSTEM - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values

# ===========================================
# DATABASE (Required)
# ===========================================
# PostgreSQL connection string for Prisma
# You can use Neon, Supabase, or any PostgreSQL provider
DATABASE_URL="mysql://root:@127.0.0.1:3306/clinic"
# ===========================================
# AUTHENTICATION (Required)
# ===========================================
# Secret key for JWT token signing (minimum 32 characters recommended)
# Generate one using: openssl rand -base64 32
JWT_SECRET="QpQT/OAniWyaRRK9t4gh0pwiIoiJY/jnBCnU7kvC8k8="

# ===========================================
# WHATSAPP INTEGRATION (Optional)
# ===========================================
# Meta/Facebook WhatsApp Business API credentials
# Required only if you want to send WhatsApp notifications
WHATSAPP_API_URL="https://graph.facebook.com/v17.0"
WHATSAPP_ACCESS_TOKEN="your-whatsapp-access-token"
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"

# ===========================================
# EMAIL INTEGRATION (Optional)
# ===========================================
# SMTP credentials for sending email notifications
# Required only if you want to send email notifications
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-specific-password"
SMTP_FROM="ClinicPro <noreply@yourclinic.com>"

# ===========================================
# AI INTEGRATION (Optional)
# ===========================================
# OpenAI API key for AI Doctor Assistant feature
# Required only if you want to use AI-powered diagnosis suggestions
OPENAI_API_KEY="sk-your-openai-api-key"

# ===========================================
# FILE UPLOADS (Optional)
# ===========================================
# Maximum file upload size in bytes (default: 10MB)
MAX_FILE_SIZE="10485760"

# Allowed file types for uploads
ALLOWED_FILE_TYPES="image/jpeg,image/png,image/gif,application/pdf"
